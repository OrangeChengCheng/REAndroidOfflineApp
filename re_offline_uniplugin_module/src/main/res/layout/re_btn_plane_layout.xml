<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:ignore="MissingDefaultResource"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:gravity="center_vertical"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintLeft_toLeftOf="parent"
    android:layout_height="wrap_content"
    android:layout_width="wrap_content">

    <LinearLayout
        android:id="@+id/re_btn_plan_tree"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@drawable/btn_plane_normal_bg">
        <Button
            android:id="@+id/re_btn_tree"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/btn_plane_tree_selector"
            android:clickable="true"
            android:focusable="true"
            />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/re_btn_plan_property"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginTop="12dp"
        android:background="@drawable/btn_plane_normal_bg">
        <Button
            android:id="@+id/re_btn_property"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/btn_plane_property_selector"
            android:clickable="true"
            android:focusable="true"
            />
    </LinearLayout>


</LinearLayout>